# This directory is a working area full of clones, logs, and scratch.
# Track ONLY the issue→PR cron's own config. Ignore everything else by default.
/*

# ...but keep the cron config + its docs:
!/.gitignore
!/README.md
!/CLAUDE.md
!/campaign-run.sh
!/campaign-prompt.txt
!/campaign-settings.json
!/cron.env.example
# weekly-budget pace gate (pre-flight called by both runners):
!/usage-gate.sh
!/pr-review-report.sh
# Rust rewrite of pr-review-report.sh (target/ ignored by the project's own .gitignore):
!/pr-review-report-rs/
!/review-run.sh
!/review-prompt.txt
!/review-settings.json
# MCP-only vetter surface (issue #52): opt-in via VETTER_MCP=1 in cron.env.
!/review-prompt-mcp.txt
!/review-settings-mcp.json
!/review-mcp.json
# Producer's clone-lifecycle MCP surface (additive; the producer keeps its Bash):
!/campaign-mcp.json
!/merge-run.sh
!/merge-prompt.txt
!/merge-settings.json
# PreToolUse hooks (deploy to the box's claude hooks dir + wire in settings.json):
!/hooks/
!/hooks/block-nix-wrap-gh.sh
!/hooks/block-cron-git-bypass.sh

# NEVER track the real deployment env (it holds the account handle / box-specific values):
/cron.env

# Explicitly NOT tracked (transient/operational/scratch), even if patterns change:
#   campaign.log, runs/, close-candidates.jsonl, DISABLED, *.lock  (runtime state)
#   WORKLOG.md, PRECOMPACT-SNAPSHOT.md                              (assistant scratch)
#   <repo> clones, ci-*/ rt-*/ fix-*/ etc.                          (work dirs)
!/sort-review-queue.sh
!/ORG-REGISTRY.md
# Producer QA doctrine (referenced by campaign-prompt step 4 + review-prompt QA gate):
!/QA-GUIDE.md
# Rust workspace + CI (rainix rust reusables gate pr-review-report):
!/Cargo.toml
!/Cargo.lock
!/.github/
!/.github/workflows/rust.yml
# Mutation-test scan records (committed so org health-checks can see scan freshness):
!/mutation-test-scans.json
# Per-run pipeline metrics (accumulates across trace rotation; committed periodically):
!/metrics/
!/metrics/runs.jsonl
# FSM-conformance snapshot (`pr-review-report human-queue --json`, overwritten each refresh);
# the rain-org-health dashboard fetches it at runtime from the raw URL — no site redeploy:
!/human-queue.json
!/refresh-human-queue.sh
# Flake exposing pr-review-report as a package (bin on the cron PATH):
!/flake.nix
!/flake.lock

# worklist read-through cache (tool-local, regenerated each run)
.worklist-cache.json
