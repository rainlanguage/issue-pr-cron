# Deployment-specific config for the issue→PR cron.
# Copy this file to `cron.env` (gitignored) and edit. campaign-run.sh sources it if present.
# Anything left unset falls back to the defaults baked into campaign-run.sh.

# GitHub handle to assign every opened PR to (REQUIRED — set this to your account or a bot):
PR_ASSIGNEE="your-github-handle"

# Org scope — the SINGLE source of truth for which GitHub orgs the pipeline covers.
# Space- (or comma-) separated. Both run scripts derive the prompt owner-flags from this and
# export it so `pr-review-report --queue` reads the same list. Edit ONLY this to change scope.
# Default (if unset): "rainlanguage cyclofinance"
# ORGS="rainlanguage cyclofinance S01-Issuer"

# Where issue clones are made (must be writable; created if missing). Default: $HOME/code
# WORK_DIR="$HOME/code"

# Producer cron (campaign-run.sh) model + per-run caps:
# MODEL="claude-sonnet-4-6"     # claude-opus-4-8 for max rigor
# FALLBACK_MODELS="claude-opus-4-8 claude-sonnet-5"   # ordered fallbacks: on a MODEL/REVIEW_MODEL usage/quota
#                                                     # limit (429) the run retries these in order, so one
#                                                     # exhausted model can't stall the pipeline.
# MAXTIME="3h"                  # hard cap per run
# KEEP_RUNS=20                  # retained per-run traces

# AI-vetting cron (review-run.sh) model + caps:
# REVIEW_MODEL="claude-sonnet-4-6"   # claude-opus-4-8 for max review rigor
# REVIEW_MAXTIME="2h"
# REVIEW_KEEP_RUNS=20

# Merge cron (merge-run.sh): SAFETY — stays dry-run (reports only) until you set this to 0.
# MERGE_DRY_RUN=1                    # set 0 to actually merge human-approved PRs
# MERGE_MODEL="claude-sonnet-4-6"
# MERGE_MAXTIME="1h"
# MERGE_KEEP_RUNS=20
