# Deployment-specific config for the issue→PR cron.
# Copy this file to `cron.env` (gitignored) and edit. campaign-run.sh sources it if present.
# Anything left unset falls back to the defaults baked into campaign-run.sh.

# GitHub handle to assign every opened PR to (REQUIRED — set this to your account or a bot):
PR_ASSIGNEE="your-github-handle"

# Where issue clones are made (must be writable; created if missing). Default: $HOME/code
# WORK_DIR="$HOME/code"

# Model + per-run caps (override the script defaults if you like):
# MODEL="claude-sonnet-4-6"     # claude-opus-4-8 for max rigor
# MAXTIME="3h"                  # hard cap per run
# KEEP_RUNS=20                  # retained per-run traces
